# Copy this file to .env (for local dev with `vercel dev`) and fill in real values.
# Never commit the real .env file.

# A long, random shared secret. Every client (Mac app, Windows app, iOS Shortcut)
# must send this exact value in the `x-api-key` header on every request.
# Generate one with: openssl rand -hex 32
CLIPBRIDGE_API_KEY=

# Redis storage (Vercel dashboard -> Storage -> Marketplace Database Providers
# -> Upstash -> Redis). Vercel injects these automatically once connected to
# your project; you only need to set them manually for local dev
# (`vercel env pull .env` will do this for you).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Blob storage, used for images so they aren't limited by the 4.5MB
# serverless function body cap. NOT reliably auto-injected -- creating a
# Blob store via Vercel's Storage tab currently wires up BLOB_STORE_ID and
# BLOB_WEBHOOK_PUBLIC_KEY, neither of which this app reads. Get this value
# from Storage -> your Blob store -> its own ".env.local" / Quickstart tab,
# and add it under Project Settings -> Environment Variables by hand (then
# redeploy -- env var changes don't apply to an already-built deployment).
# Sync clients also need this value directly (see README) to upload images
# straight to Blob storage.
BLOB_READ_WRITE_TOKEN=

# Pusher (create a free app at https://dashboard.pusher.com/ -> Channels).
# Found on your app's "App Keys" page.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Optional: max requests per client IP per 60-second window (default 60).
RATE_LIMIT_MAX_REQUESTS=60

# Optional. iOS can't hold a persistent Pusher connection in the background,
# so real-time push to iPhone goes through Pushcut (https://pushcut.co)
# instead. Create a Notification in the Pushcut app, copy its webhook URL
# here. Leave unset to skip iPhone push notifications entirely.
PUSHCUT_WEBHOOK_URL=
